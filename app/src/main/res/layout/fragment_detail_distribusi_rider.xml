<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        android:clipToPadding="false"
        android:paddingBottom="90dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvHeaderDetailDist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Muatan Jatah Keliling Motor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#3E2723"
                android:layout_margin="8dp"/>

            <!-- PENYESUAIAN BARU: riwayat distribusi per sesi (pending & diterima tetap tampil) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Riwayat Distribusi per Sesi"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#3E2723"
                android:layout_marginStart="8dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSesiDistribusi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#D7CCC8"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stok Kumulatif Saat Ini (Sudah Diterima)"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#3E2723"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="4dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDetailDistribusiRider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabTambahJatahSuplai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:backgroundTint="#3E2723"
        app:tint="#FFFFFF"
        app:srcCompat="@android:drawable/ic_input_add"
        android:contentDescription="Tambah Suplai" />
</RelativeLayout>