<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_dashboard"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- BUNGKUS DENGAN APPBARLAYOUT UNTUK MEMBERIKAN RUANG LEBIH LUAS KE BAWAH -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#6200EE"
        app:elevation="4dp">

        <!-- TOOLBAR CUSTOM SEBAGAI TOP NAVIGATION BAR -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/rider_toolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:titleTextColor="#FFFFFF"
            app:title="Tuan Kopi - Rider"
            app:menu="@menu/menu_rider_top" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Container Wadah Fragment (Mengambil sisa ruang yang ada) -->
    <FrameLayout
        android:id="@+id/rider_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom Navigation Bar -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/rider_bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:backgroundTint="#FFFFFF"
        app:itemIconTint="#3E2723"
        app:itemTextColor="#3E2723"
        app:menu="@menu/menu_rider_dashboard" />

</LinearLayout>