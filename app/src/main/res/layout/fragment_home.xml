<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FB"
    android:padding="16dp"
    tools:ignore="HardcodedText">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:paddingHorizontal="4dp">

            <TextView
                android:id="@+id/tvSelamatDatang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selamat datang,"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#191C1E"/>

            <TextView
                android:id="@+id/tvNamaDashboard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Memuat profil..."
                android:textSize="14sp"
                android:textColor="#757682"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- ======== KARTU OMSET HARIAN ======== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Omset Harian"
                    android:textSize="12sp"
                    android:textColor="#444651"
                    android:letterSpacing="0.05"/>
                <TextView
                    android:id="@+id/tvOmsetHarian"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 4.250.000"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#00236F"
                    android:layout_marginTop="4dp"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_trending_up"
                        app:tint="#2E7D32"
                        tools:ignore="ContentDescription"/>
                    <TextView
                        android:id="@+id/tvTrendHarian"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+12% vs kemarin"
                        android:textSize="12sp"
                        android:textColor="#2E7D32"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ======== KARTU OMSET MINGGUAN ======== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Omset Mingguan"
                    android:textSize="12sp"
                    android:textColor="#444651"
                    android:letterSpacing="0.05"/>
                <TextView
                    android:id="@+id/tvOmsetMingguan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 28.100.000"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#00236F"
                    android:layout_marginTop="4dp"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_trending_up"
                        app:tint="#2E7D32"
                        tools:ignore="ContentDescription"/>
                    <TextView
                        android:id="@+id/tvTrendMingguan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+5% vs minggu lalu"
                        android:textSize="12sp"
                        android:textColor="#2E7D32"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ======== KARTU OMSET BULANAN ======== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Omset Bulanan"
                    android:textSize="12sp"
                    android:textColor="#444651"
                    android:letterSpacing="0.05"/>
                <TextView
                    android:id="@+id/tvOmsetBulanan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 112.450.000"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#00236F"
                    android:layout_marginTop="4dp"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_trending_down"
                        app:tint="#C62828"
                        tools:ignore="ContentDescription"/>
                    <TextView
                        android:id="@+id/tvTrendBulanan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-2% vs bulan lalu"
                        android:textSize="12sp"
                        android:textColor="#C62828"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ======== KARTU TOTAL LABA BERSIH (Dark) ======== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#00236F">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Laba Bersih"
                    android:textSize="12sp"
                    android:textColor="#CCD5FF"
                    android:letterSpacing="0.05"/>
                <TextView
                    android:id="@+id/tvLabaBersih"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 45.200.000"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="4dp"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_payments"
                        app:tint="#DCE1FF"
                        tools:ignore="ContentDescription"/>
                    <TextView
                        android:id="@+id/tvMarginLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Margin 40.2%"
                        android:textSize="12sp"
                        android:textColor="#DCE1FF"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ======== TREN PENJUALAN REAL-TIME ======== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header: Title + Toggle -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Tren Penjualan\nReal-time"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#191C1E"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_toggle_group"
                        android:padding="2dp">
                        <TextView
                            android:id="@+id/btnHourly"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hourly"
                            android:textSize="12sp"
                            android:textColor="#00236F"
                            android:background="@drawable/bg_toggle_selected"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"/>
                        <TextView
                            android:id="@+id/btnDaily"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Daily"
                            android:textSize="12sp"
                            android:textColor="#757682"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"/>
                    </LinearLayout>
                </RelativeLayout>

                <!-- Bar Chart -->
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/barChartTren"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ======== PAYMENT METHOD ======== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Payment Method"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#191C1E"
                    android:layout_marginBottom="16dp"/>

                <!-- Pie Chart -->
                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieChartMetode"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center_horizontal"/>

                <!-- Legend -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <View
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/circle_primary"
                                android:layout_marginEnd="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="QRIS"
                                android:textSize="14sp"
                                android:textColor="#191C1E"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvQrisAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="Rp 2.762.500"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#191C1E"/>
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <View
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/circle_primary_fixed"
                                android:layout_marginEnd="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tunai"
                                android:textSize="14sp"
                                android:textColor="#191C1E"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvTunaiAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="Rp 1.487.500"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#191C1E"/>
                    </RelativeLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ======== LIVE RANKING RIDER ======== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Card Header -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_stars"
                            app:tint="#F59E0B"
                            android:layout_marginEnd="6dp"
                            tools:ignore="ContentDescription"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Live Ranking Rider"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#191C1E"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/circle_green"
                            android:layout_marginEnd="4dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Updating Live"
                            android:textSize="11sp"
                            android:textColor="#444651"/>
                    </LinearLayout>
                </RelativeLayout>

                <!-- Table Header -->
                <!-- Cari baris "Table Header" di dalam fragment_home.xml milikmu dan perbarui teksnya -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="#F3F4F6">
                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:text="Rank"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#444651"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Rider"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#444651"/>
                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="Omset"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#444651"
                    android:gravity="end"/>
                </LinearLayout>

                <!-- Table Rows Container -->
                <LinearLayout
                    android:id="@+id/containerRankingRider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>