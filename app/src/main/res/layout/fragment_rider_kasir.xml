<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FB">

    <!-- Status Bar Kunci Informasi Kasir -->
    <TextView
        android:id="@+id/tvKasirStatusWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#C62828"
        android:text="KASIR TERKUNCI! Silakan MULAI JUALAN terlebih dahulu di Dashboard."
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="8dp"
        android:visibility="gone"/>

    <!-- Daftar Menu Kopi yang Tersedia di Motor -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMenuKasirRider"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tvKasirStatusWarning"
        android:layout_above="@id/layoutPanelTransaksi"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- Bottom Sheet Panel Perhitungan Belanja -->
    <LinearLayout
        android:id="@+id/layoutPanelTransaksi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:padding="16dp"
        android:layout_alignParentBottom="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Keranjang:"
                android:textSize="14sp"
                android:textColor="#757682"/>
            <TextView
                android:id="@+id/tvTotalHargaKeranjang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Rp 0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#00236F"/>
        </RelativeLayout>

        <!-- Pilihan Metode Pembayaran -->
        <RadioGroup
            android:id="@+id/rgMetodePembayaran"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="12dp">
            <RadioButton
                android:id="@+id/rbBayarTunai"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💵 CASH / TUNAI"
                android:checked="true"
                android:textSize="13sp"/>
            <RadioButton
                android:id="@+id/rbBayarQris"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📱 QRIS DIGITAL"
                android:textSize="13sp"/>
        </RadioGroup>

        <!-- Blok Input Perhitungan Cash Terbuka Dinamis -->
        <LinearLayout
            android:id="@+id/layoutInputCashTunai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/etUangBayarTunai"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:hint="Masukkan Uang Tunai Diterima"
                android:inputType="number"
                android:textSize="14sp"
                android:background="@android:drawable/edit_text"/>

            <TextView
                android:id="@+id/tvUangKembalianTunai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kembalian: Rp 0"
                android:textSize="13sp"
                android:textStyle="bold|italic"
                android:textColor="#2E7D32"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnSimpanTransaksiFinal"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="BAYAR &amp; CETAK STRUK"
            android:backgroundTint="#00236F"
            android:textStyle="bold"/>
    </LinearLayout>
</RelativeLayout>