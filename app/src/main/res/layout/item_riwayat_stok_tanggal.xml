<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="2dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardCornerRadius="12dp"
    app:cardElevation="1.5dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Info Kiri: Tanggal dan Modal -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@+id/tvRiwayatStatusStok">

            <TextView
                android:id="@+id/tvRiwayatTglDokumen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YYYY-MM-DD"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#00236F"/>

            <TextView
                android:id="@+id/tvRiwayatModalBawaan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Modal Kembalian: Rp 0"
                android:textSize="12sp"
                android:textColor="#757682"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Info Kanan: Status Badge -->
        <TextView
            android:id="@+id/tvRiwayatStatusStok"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="AKTIF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:background="#E8F5E9"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"/>

    </RelativeLayout>
</androidx.cardview.widget.CardView>