<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FB">

    <!-- Baris Header Tombol Back -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#FFFFFF">

        <ImageView
            android:id="@+id/btnBackDetail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="?attr/homeAsUpIndicator"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:layout_marginEnd="8dp"
            app:tint="#191C1E"/>

        <TextView
            android:id="@+id/tvInfoTanggalClosing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Closing: --"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#191C1E"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rangkuman Omset Harian"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="16dp" />

            <!-- Baris Informasi Data -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Omset QRIS Sistem:" />
                <TextView android:id="@+id/tvQrisSistem" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" android:text="Rp 0"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Omset Tunai Sistem:" />
                <TextView android:id="@+id/tvTunaiSistem" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" android:text="Rp 0"/>
            </LinearLayout>

            <!-- TOTAL PENJUALAN -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Total Penjualan (Tunai + QRIS):" android:textColor="#00236F" android:textStyle="bold"/>
                <TextView android:id="@+id/tvTotalPenjualanSistem" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" android:textColor="#00236F" android:text="Rp 0"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Modal Kembalian:" />
                <TextView android:id="@+id/tvModalSistem" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" android:text="Rp 0"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginVertical="16dp"/>

            <TextView
                android:id="@+id/tvTargetFisik"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Target Uang di Laci: Rp 0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#C62828"
                android:layout_marginBottom="16dp"/>

            <!-- WADAH 1: FORM INPUT -->
            <LinearLayout
                android:id="@+id/layoutInputFisik"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Masukkan Uang Tunai Fisik (Modal + Omset Tunai):"/>

                <EditText
                    android:id="@+id/etUangFisik"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:hint="Contoh: 150000"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvSelisih"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Selisih: Rp 0"
                    android:textStyle="italic"
                    android:layout_marginBottom="24dp"/>

                <Button
                    android:id="@+id/btnKirimClosing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Kirim Laporan &amp; Kunci Aplikasi"
                    android:backgroundTint="#00236F" />
            </LinearLayout>

            <!-- WADAH 2: PANEL STATUS VALIDASI -->
            <LinearLayout
                android:id="@+id/layoutStatusClosing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Laporan Selesai &amp; Terkunci!"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#191C1E"
                    android:gravity="center"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvInfoFisikTerkirim"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Uang Disetorkan: Rp 0"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Status Validasi Owner:"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:textColor="#757575"/>

                <TextView
                    android:id="@+id/tvStatusValidasi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PENDING"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp"
                    android:textColor="#F57F17"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>