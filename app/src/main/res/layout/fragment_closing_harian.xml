<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FB">

    <!-- HEADER DISERAGAMKAN -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#FFFFFF">

        <ImageView
            android:id="@+id/btnBackDetail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="?attr/homeAsUpIndicator"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:layout_marginEnd="8dp"
            app:tint="#191C1E"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvInfoTanggalClosing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Closing Laporan"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#191C1E"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rekapitulasi dan setor omset harian"
                android:textSize="12sp"
                android:textColor="#757682"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Data Sistem POS Tuan Kopi"
                        android:textStyle="bold"
                        android:textColor="#757682"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Omset QRIS (Otomatis):" android:textColor="#444651"/>
                        <TextView android:id="@+id/tvQrisSistem" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" android:textColor="#191C1E" android:text="Rp 0"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Omset Tunai (Manual):" android:textColor="#444651"/>
                        <TextView android:id="@+id/tvTunaiSistem" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" android:textColor="#191C1E" android:text="Rp 0"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Total Penjualan:" android:textColor="#191C1E" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvTotalPenjualanSistem" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" android:textColor="#191C1E" android:text="Rp 0"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginVertical="16dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Modal Kembalian Awal:" android:textColor="#444651"/>
                        <TextView android:id="@+id/tvModalSistem" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" android:textColor="#191C1E" android:text="Rp 0"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTargetFisik"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Target Uang di Laci: Rp 0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#C62828"
                        android:gravity="center"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/layoutInputFisik"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textColor="#191C1E"
                    android:text="Input Laporan Fisik"/>

                <EditText
                    android:id="@+id/etUangFisik"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:inputType="number"
                    android:hint="Hitung &amp; Ketik Total Lembaran Uang..."
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvSelisih"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Selisih Perhitungan: Rp 0"
                    android:textStyle="italic"
                    android:textColor="#757682"
                    android:layout_marginBottom="24dp"/>

                <Button
                    android:id="@+id/btnKirimClosing"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="LAPOR PENJUALAN"
                    android:backgroundTint="#00236F"
                    android:textStyle="bold" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/layoutStatusClosing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="visible"
                    android:layout_marginTop="20dp"
                    app:cardElevation="2dp"
                    app:cardCornerRadius="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#FFFFFF"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Laporan Selesai &amp; Terkunci!"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="#191C1E"
                            android:gravity="center"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvInfoFisikTerkirim"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Total Setoran Diserahkan: Rp 0"
                            android:textSize="14sp"
                            android:textColor="#757682"
                            android:gravity="center"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:id="@+id/tvStatusValidasi"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="MENUNGGU OWNER VALIDASI"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:gravity="center"
                            android:textColor="#F57F17"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>