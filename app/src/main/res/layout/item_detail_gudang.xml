<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvDetailNamaKopi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/tvDetailHargaKopi"
                android:text="Nama Kopi"
                android:textStyle="bold"
                android:textColor="#3E2723"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvDetailHargaKopi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Rp 0"
                android:textStyle="bold"
                android:textColor="#E65100"
                android:textSize="14sp"/>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:weightSum="3">

            <TextView
                android:id="@+id/tvMasukAwal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Awal: 0"
                android:textSize="12sp"
                android:textColor="#555555"/>

            <TextView
                android:id="@+id/tvTambahanStok"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tambahan: 0"
                android:textSize="12sp"
                android:textColor="#6A1B9A"/>

            <TextView
                android:id="@+id/tvStokTotalKumulatif"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total: 0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#00236F"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:weightSum="2">

            <TextView
                android:id="@+id/tvDialokasikan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Diambil: 0"
                android:textSize="12sp"
                android:textColor="#E65100"/>

            <TextView
                android:id="@+id/tvSisaGudang"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sisa: 0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:gravity="end"/>
        </LinearLayout>

        <View
            android:id="@+id/viewDividerAksi"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="12dp"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/layoutAksi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:weightSum="2"
            android:visibility="gone">

            <Button
                android:id="@+id/btnEditItem"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="EDIT AWAL"
                android:textSize="11sp"
                android:textStyle="bold"
                android:backgroundTint="#3E2723"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

            <Button
                android:id="@+id/btnHapusItem"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="HAPUS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:backgroundTint="#D32F2F"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>