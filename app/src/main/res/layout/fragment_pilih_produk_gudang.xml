<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvHeaderPilih"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pilih Menu Kopi"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#3E2723"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPilihProduk"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tvHeaderPilih"
        android:layout_above="@id/btnSimpanBatchGudang"
        android:layout_marginVertical="12dp"/>

    <Button
        android:id="@+id/btnSimpanBatchGudang"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_alignParentBottom="true"
        android:text="SIMPAN"
        android:backgroundTint="#3E2723"
        android:textStyle="bold"/>
</RelativeLayout>