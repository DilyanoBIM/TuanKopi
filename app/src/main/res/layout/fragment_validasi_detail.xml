<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detail Setoran Rider"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <TextView android:id="@+id/tvNamaDanTanggal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" android:layout_marginBottom="16dp"/>

        <TextView android:id="@+id/tvTunaiSistem" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvQrisSistem" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvTotalOmset" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:textStyle="bold"/>

        <TextView android:id="@+id/tvUangFisikDilaporkan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#2E7D32" android:textStyle="bold" android:layout_marginBottom="16dp"/>

        <TextView android:id="@+id/tvStatusSelisih" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/etCatatanOwner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Catatan Owner (Wajib jika ada selisih uang fisik)"
            android:inputType="textMultiLine"
            android:lines="3"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnTolakSelisih"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ada Selisih"
                android:backgroundTint="#C62828"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnValidasiCocok"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Validasi Cocok"
                android:backgroundTint="#2E7D32"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>